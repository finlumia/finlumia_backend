# Environment files
.env
.env.*

# Keys and certificates
*.pem
*.key
*.p12
*.jks
*.pfx

# Generic secret artifacts
*credentials*
*secret*
*token*

# Runtime/packaging artifacts
*.class
*.jar
*.war
*.ear
*.log
*.tmp
*.temp
*.pid
hs_err_pid*
replay_pid*

# OS / editor leftovers
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo

# SQL dump files (backups, exports locais)
*.sql
!docker/bases/migrations/*.sql

# Backup do banco usado por finlumia_backend.sh / docker-compose.dev.yml
# (contem dados reais, nunca deve ir para o git)
docker/backup/*.backup
!docker/backup/.gitkeep

# Arquivos com caminho de Windows gerados acidentalmente no workspace
# (clientes de sync no Windows por vezes trocam ":" por outro glifo, ex.: U+F03A,
# entao o padrao "C:*" sozinho nao pega todos os casos)
C:*
C*Downloads*
C*Users*


