shared/src/main/resources/application-pro.properties
shared/src/main/resources/shared-dev.properties
shared/src/main/resources/shared-pro.properties
**/application-dev.properties
**/application-pro.properties
**/shared-dev.properties
**/shared-pro.properties
docker/base/*.tar
docker/bases/*.tar
docker/bases/finlumia_transactions
docker/test/*.tar
