# Default: ignore everything to keep build context tiny.
**

# Include only Dockerfiles used by the build scripts.
!docker/scripts/
!docker/scripts/*.Dockerfile
!docker/scripts/db-restore.sh
!docker/scripts/db-harden-security.sh

# Include only application JAR artifacts required by each module image.
!configurator/build/libs/*.jar
!docs/build/libs/*.jar
!document/build/libs/*.jar
!identify/build/libs/*.jar
!movement/build/libs/*.jar
