# Variaveis de ambiente para o Docker Compose
# Como usar: copie este arquivo para .env e preencha os valores reais.
# O arquivo .env esta no .gitignore e NAO deve ser versionado.

DB_USERNAME=papadopoulos
DB_PASSWORD=TROQUE_ESTA_SENHA
DB_NAME=finlumia_transactions

# ---- CORS: origens que o browser pode chamar os microservicos ----
# Desenvolvimento (default no codigo - nao precisa setar)
# ALLOWED_ORIGINS=http://localhost:3000
# Homologacao:
# ALLOWED_ORIGINS=https://homolog.finlumia.com.br
# Producao:
# ALLOWED_ORIGINS=https://app.finlumia.com.br
# Multiplas origens (separadas por virgula):
# ALLOWED_ORIGINS=https://homolog.finlumia.com.br,https://app.finlumia.com.br
ALLOWED_ORIGINS=http://localhost:3000

# ---- JWT (identify) ----
# Minimo 32 caracteres. Gerar com: openssl rand -hex 32
JWT_SECRET=TROQUE_ESTE_SEGREDO_MIN_32_CHARS

# ---- Token de comunicacao interna (service-to-service) ----
# Gerar com: openssl rand -hex 24
INTERNAL_SERVICE_TOKEN=TROQUE_ESTE_TOKEN_INTERNO

# ---- E-mail (SMTP) — cadastro, recuperacao de senha, orcamento, suporte ----
# SMTP_USERNAME e a caixa principal; os MAIL_FROM_* sao aliases dela configurados
# no provedor (Zoho) — precisam bater EXATAMENTE com os aliases criados la, senao
# o envio e rejeitado.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USERNAME=me@thiagobenevide.com
SMTP_PASSWORD=TROQUE_ESTA_SENHA
MAIL_FROM_ACCOUNT=account-finlumia@thiagobenevide.com
MAIL_FROM_RECOVER=recorver-finlumia@thiagobenevide.com
MAIL_REPLY_TO=support-finlumia@thiagobenevide.com
